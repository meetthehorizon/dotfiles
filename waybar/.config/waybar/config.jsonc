{
  // bar configuration
  "layer": "top",
  "margin": "5 10 0 10",
  // "spacing": 5,
  "name": "waybar-top",
  "reload_style_on_change": true,

  // modules
  "modules-left": ["hyprland/workspaces"],
  "modules-center": ["hyprland/window"],
  "modules-right": [
    "custom/fan",
    "backlight",
    "wireplumber",
    "battery",
    "network",
    "clock"
  ],

  "hyprland/workspaces": {
    "format": "{icon} {windows}",
    "window-rewrite-default": "î°‡",
    "format-window-separator": " |",
    "window-rewrite": {
      "code": "َ°¨‍",
      "kitty": "î¯ٹ",
      "wezterm": "î¼پ",
      "obsidian": "َ° ®",
      "rofi": "َ°®«",
      "spotify": "َ°“‡",
      "steam": "َ°““",
      "class<zen>": "َ°ˆ¹"
    }
  },

  "hyprland/window": {
    "format": "{title}",
    "rewrite": {
      "(.*) - (.*) - Obsidian (.*)": "$1 ($2)",
      "Spotify Premium": "Spotify",
      "(.*)- Visual Studio Code": "VS Code",
      "(.*) â€” Zen Browser": "Zen",
      "(.*) - fish": "> [$1]"
    },
    "separate-outputs": true
  },

  // module configuration
  "network": {
    "interface": "wlan0",
    "format": "{ifname}",
    "format-wifi": "{signalStrength}% {icon}",
    "format-ethernet": "{ipaddr}/{cidr} ïƒپ ",
    "format-disconnected": "َ°¤­ ",
    "format-icons": ["َ°¤¯ ", "َ°¤ں ", "َ°¤¢ ", "َ°¤¥ ", "َ°¤¨ "],
    "tooltip-format": "{ifname} via {gwaddr} َ°ٹ—",
    "tooltip-format-wifi": "{essid}",
    "tooltip-format-ethernet": "{ifname} ïƒپ ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50
  },

  "custom/fan": {
    "format": "َ°ˆگ",
    "tooltip-format": "Fan Boost",
    "on-click": "kitty -e bash ~/Scripts/fanboost.sh"
  },

  "backlight": {
    "format": "{percent}% {icon}",
    "format-icons": [
      "îژ¨ ",
      "îژ§ ",
      "îژ¦ ",
      "îژ¥ ",
      "îژ¤ ",
      "îژ£ ",
      "îژ¢ ",
      "îژ، ",
      "îژ  ",
      "îژں ",
      "îژ‍ ",
      "îژ‌ ",
      "îژœ ",
      "îڈ£ "
    ]
  },

  "wireplumber": {
    "format": "{volume}% {icon}",
    "format-muted": "َ°‌ں",
    "format-icons": ["َ°•؟", "َ°–€", "َ°•¾"]
  },

  "battery": {
    "interval": 1,
    "states": {
      "bat_100": 100,
      "bat_90": 90,
      "bat_80": 80,
      "bat_70": 70,
      "bat_60": 60,
      "bat_50": 50,
      "bat_40": 40,
      "bat_30": 30,
      "bat_20": 20,
      "bat_10": 10,
      "bat_0": 0
    },
    "format-charging": "{capacity}% َ°‚„",
    "format-bat_100": "{capacity}% َ°پ¹",
    "format-bat_90": "{capacity}% َ°‚‚",
    "format-bat_80": "{capacity}% َ°‚پ",
    "format-bat_70": "{capacity}% َ°‚€",
    "format-bat_60": "{capacity}% َ°پ؟",
    "format-bat_50": "{capacity}% َ°پ¾",
    "format-bat_40": "{capacity}% َ°پ½",
    "format-bat_30": "{capacity}% َ°پ¼",
    "format-bat_20": "{capacity}% َ°پ»",
    "format-bat_10": "{capacity}% َ°پ؛",
    "format-bat_0": "{capacity}% َ°‚ƒ",

    "tooltip": true,
    "tooltip-format": "{power}W",
    "max-length": 25
  },

  "clock": {
    "format": "{:%H:%M (%Z)}",
    "tooltip-format": "{tz_list}",
    "timezones": [
      "Asia/Kolkata",
      "Asia/Tokyo",
      "America/New_York",
      "America/Los_Angeles",
      "Europe/London",
      "Europe/Berlin",
      "Asia/Singapore",
      "Australia/Sydney"
    ]
  }
}
