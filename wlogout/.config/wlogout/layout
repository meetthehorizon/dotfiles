{
    "label" : "lock",
    "action" : "hyprlock",
    "keybind" : "l"
}
{
    "label" : "reboot",
    "action" : "systemctl reboot",
    "keybind" : "r"
}
{
    "label" : "logout",
    "action" : "loginctl terminate-user $USER",
    "keybind" : "e"
}
{
    "label" : "shutdown",
    "action" : "systemctl poweroff",
    "keybind" : "s"
}
{
    "label": "hibernate",
    "action": "systemctl hibernate",
    "keybind": "h"
}
{
    "label": "suspend",
    "action": "systemctl suspend",
    "keybind": "u"
}