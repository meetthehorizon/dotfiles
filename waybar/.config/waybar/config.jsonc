{
  // bar configuration
  "layer": "top",
  "margin": "0 0 0 0",
  "name": "waybar-top",
  "reload_style_on_change": true,

  // modules
  "modules-left": ["user", "tray", "mpris"],
  "modules-center": ["hyprland/workspaces"],
  "modules-right": [
    "battery",
    "power-profiles-daemon",
    "wireplumber",
    "bluetooth",
    "network",
    "clock#time",
    "clock#date",
  ],

  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "ïƒ§",
      "performance": "ïƒ§",
      "balanced": "ï‰ژ",
      "power-saver": "ïپ¬",
    },
  },

  "image#logo": {
    "path": "/home/conart/.face",
    "size": 25,
  },

  "user": {
    "format": "َ°£‡ {work_H}:{work_M}",
    "interval": 60,
    "height": 30,
    "width": 30,
    "swap-icon-label": false,
  },

  "mpris": {
    "interval": 1,
    "format": "{player_icon} {dynamic}",
    "format-paused": "{status_icon} {dynamic}",
    "dynamic-order": ["title"],
    "tooltip-format": "î°›\t{title}\nï‰’\t{position} / {length}\nَ°ک‰\t{artist}\nï€­ \t{album}",
    "dynamic-separator": " ",
    "player-icons": {
      "default": "ïپ‹",
      "mpv": "ًںژµ",
      "vlc": "َ°•¼",
      "spotify": "ï†¼",
      "firefox": "ï‰©",
    },
    "status-icons": {
      "paused": "î€…",
    },
    "on-click": "playerctl play-pause",
    "on-click-right": "playerctl next",
    "on-click-middle": "playerctl previous",
  },

  "tray": {
    "icon-size": 17,
    "spacing": 4,
  },

  "hyprland/workspaces": {
    "format": "{icon} {windows}",
    "window-rewrite-default": "",
    "format-window-separator": " ",
    "window-rewrite": {
      "code": "َ°¨‍",
      "kitty": "î¯ٹ",
      "class<org.wezfurlong.wezterm>": "î¼پ",
      "class<org.wezfurlong.wezterm> title<Yazi.*>": "َ°‰“",
      "class<org.wezfurlong.wezterm> title<gdu>": "ïƒ‡",
      "class<org.wezfurlong.wezterm> title<nmtui>": "َ°›³",
      "class<org.wezfurlong.wezterm> title<nvim>": "َ°…´",
      "obsidian": "َ° ®",
      "rofi": "ïگژ",
      "spotify": "َ°“‡",
      "steam": "َ°““",
      "class<firefox>": "î™ک",
      "title<.*Bitwarden.*>": "î´¥",
      "zathura": "َ±”—",
      "class<discord>": "َ°™¯",
      "title<bluetuith>": "َ°‚±",
      "class<.*Cryptomator.*>": "َ°ˆ،",
      "class<org.gnome.seahorse.Application>": "ï‚„",
      "class<Godot.*>": "îں®",
      "class<anki>": "َ°ک¸",
      "class<com.obsproject.Studio>": "َ°•§",
      "class<hyprpolkitagent>": "َ°Œ¾",
      "class<timeshift.*>": "َ°پ¯",
      "class<antigravity.*>": "َ°…´",
      "class<hyprland.*>": "ïچ™",
      "class<zen.*>": "َ°–ں",
      "class<scrcpy.*>": "ï„‹",
      "class<variety>": "َ°¸‰",
      "class<superProductivity>": "î®»",
    },
    "swap-icon-label": true,
  },

  "hyprland/window": {
    "format": "{title}",
    "rewrite": {
      "(.*) - (.*) - Obsidian (.*)": "$1 ($2)",
      "Spotify Premium": "Spotify",
      "(.*)- Visual Studio Code": "VS Code",
      "(.*) â€” Zen Browser": "Zen",
      "(.*) - fish": "> [$1]",
      "(.*).(.*).zathura": "Zathura",
    },
    "separate-outputs": true,
    "swap-icon-label": false,
  },

  "bluetooth": {
    "format": "ïٹ” {status}",
    "format-off": "َ°‚²",
    "format-disabled": "َ°‚²",
    "format-on": "َ°‚¯",
    "format-connected": "َ°‚± {num_connections}",
    "tooltip-format": "{controller_alias}",
    "tooltip-format-connected": "{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\tَ°پ¹ {device_battery_percentage}%",
  },

  "network": {
    "format": "{ifname}",
    "format-wifi": "{essid} {icon}",
    "format-ethernet": "{ipaddr}/{cidr} ïƒپ ",
    "format-disconnected": "َ°¤­",
    "format-icons": ["َ°¤¯", "َ°¤ں", "َ°¤¢", "َ°¤¥", "َ°¤¨"],
    "tooltip-format": "{ifname} via {gwaddr} َ°ٹ—",
    "tooltip-format-wifi": "{essid}",
    "tooltip-format-ethernet": "{ifname} ïƒپ ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 50,
  },

  "backlight": {
    "format": "{percent}% {icon}",
    "format-icons": [
      "îژ¨ ",
      "îژ§ ",
      "îژ¦ ",
      "îژ¥ ",
      "îژ¤ ",
      "îژ£ ",
      "îژ¢ ",
      "îژ، ",
      "îژ  ",
      "îژں ",
      "îژ‍ ",
      "îژ‌ ",
      "îژœ ",
      "îڈ£ ",
    ],
  },

  "wireplumber": {
    "format": "{volume}% {icon}",
    "format-muted": "َ°‌ں",
    "format-icons": ["َ°•؟", "َ°–€", "َ°•¾"],
  },

  "battery": {
    "interval": 1,
    "states": {
      "bat_100": 100,
      "bat_90": 90,
      "bat_80": 80,
      "bat_70": 70,
      "bat_60": 60,
      "bat_50": 50,
      "bat_40": 40,
      "bat_30": 30,
      "bat_20": 20,
      "bat_10": 10,
      "bat_0": 0,
    },
    "format-charging": "{capacity}% َ°‚„",
    "format-bat_100": "{capacity}% َ°پ¹",
    "format-bat_90": "{capacity}% َ°‚‚",
    "format-bat_80": "{capacity}% َ°‚پ",
    "format-bat_70": "{capacity}% َ°‚€",
    "format-bat_60": "{capacity}% َ°پ؟",
    "format-bat_50": "{capacity}% َ°پ¾",
    "format-bat_40": "{capacity}% َ°پ½",
    "format-bat_30": "{capacity}% َ°پ¼",
    "format-bat_20": "{capacity}% َ°پ»",
    "format-bat_10": "{capacity}% َ°پ؛",
    "format-bat_0": "{capacity}% َ°‚ƒ",
    "tooltip": true,
    "tooltip-format": "{power}W",
    "max-length": 25,
  },

  "clock#time": {
    "format": "ïگ؛ {:%H:%M}",
    "tooltip-format": "{:%Z}",
  },

  "clock#date": {
    "format": "ï‰²  {:%a, %d %b}",
    "tooltip-format": "{:%A, %d %B %Y}",
  },
}
